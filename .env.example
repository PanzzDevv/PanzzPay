# Recommended on local machines: point to a newly generated service-account file.
GOOGLE_APPLICATION_CREDENTIALS=C:\\secure\\panzzpay-service-account.json
FIREBASE_PROJECT_ID=panzzpay

# Recommended on Vercel: store the complete service-account JSON as one secret.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"panzzpay","private_key":"-----BEGIN PRIVATE KEY-----\\nREPLACE_ME\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com"}

# Firebase Web App configuration used by Google popup authentication.
FIREBASE_API_KEY=replace-me
FIREBASE_AUTH_DOMAIN=panzzpay.firebaseapp.com
FIREBASE_STORAGE_BUCKET=panzzpay.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=replace-me
FIREBASE_APP_ID=replace-me

# Set to true in production if requests must fail instead of using local fallback.
FIREBASE_REQUIRED=true
NODE_ENV=production
ALLOWED_ORIGINS=https://your-domain.example
API_RATE_LIMIT=120
AUTH_RATE_LIMIT=10
WEBHOOK_RATE_LIMIT=60

# Super Admin must already exist in Firebase Authentication.
SUPER_ADMIN_UID=replace-with-firebase-auth-uid
SUPER_ADMIN_EMAIL=admin@example.com
