<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER BRAND HERO CARD WITH OFFICIAL LOGO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_card"
            android:padding="22dp"
            android:orientation="vertical"
            android:gravity="center">

            <!-- OFFICIAL PANZZPAY LOGO -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_logo"
                android:contentDescription="PanzzPay Logo"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PanzzPay Forwarder v2.0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatic QRIS Notification Listener &amp; Webhook Gateway"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvPermissionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Izin Notifikasi: Mengecek..."
                android:textColor="#10B981"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_status"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- SERVICE TOGGLE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bento_card"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status Layanan Listener"
                    android:textColor="#0F172A"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvServiceStatusSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Membaca notifikasi transfer e-wallet secara otomatis"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchService"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                tools:ignore="UseSwitchCompatOrMaterialXml" />
        </LinearLayout>

        <!-- WEBHOOK URL CONFIGURATION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bento_card"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target Webhook URL PanzzPay Anda:"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salin URL Webhook dari Portal Merchant PanzzPay Anda"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <EditText
                android:id="@+id/etWebhookUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="https://panzzpay.vercel.app/api/webhook/callback?token=pz_wh_..."
                android:inputType="textUri|textMultiLine"
                android:maxLines="3"
                android:scrollHorizontally="false"
                android:textSize="12sp"
                android:layout_marginTop="10dp"
                android:padding="12dp"
                android:background="@drawable/bg_input_box"
                android:textColor="#0F172A" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnPasteUrl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📋 Tempel URL"
                    android:backgroundTint="#475569"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.3"
                    android:text="💾 Simpan URL"
                    android:backgroundTint="#2563EB"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- SUPPORTED APPS & E-WALLETS INFO CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bento_card"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aplikasi Terhubung &amp; Otomatis Dibaca:"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DANA • ShopeePay • GoPay • OVO • m-BCA • BRImo • Livin Mandiri • BSI Mobile • SeaBank"
                android:textColor="#059669"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- LIVE LOG TERMINAL CONSOLE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_console_terminal"
            android:padding="16dp"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💻 LOG AKTIVITAS FORWARDER (REAL-TIME):"
                android:textColor="#38BDF8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLogConsole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="[READY] PanzzPay Notification Listener siap menerima data notifikasi..."
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <!-- ACTION BUTTONS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bento_card"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnGrantPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 🔔 Buka Setting Izin Akses Notifikasi"
                android:backgroundTint="#059669"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnTestWebhook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. ⚡ Tes Kirim Webhook Ke Server PanzzPay"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
