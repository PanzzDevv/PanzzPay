<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Brand Logo / Banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0F172A"
            android:padding="20dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PanzzPay Forwarder"
                android:textColor="#FFD200"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aplikasi Listener Notifikasi QRIS Otomatis"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Service Toggle Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Status Layanan (Service State)"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switchService"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Webhook URL Configuration Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alamat Target Webhook PanzzPay:"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etWebhookUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="http://domain-anda.com/api/webhook/callback"
                android:inputType="textUri"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:background="#F1F5F9" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Simpan Webhook URL"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Action Buttons Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnGrantPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Aktifkan Izin Akses Notifikasi"
                android:backgroundTint="#059669"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnTestWebhook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Tes Kirim Webhook PanzzPay"
                android:backgroundTint="#0F172A"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
