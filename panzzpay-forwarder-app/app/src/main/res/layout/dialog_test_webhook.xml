<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/test_dialog_title"
        android:textAppearance="@style/TextAppearance.PanzzPay.SectionTitle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="@string/test_dialog_subtitle"
        android:textAppearance="@style/TextAppearance.PanzzPay.Body" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/provider_label"
        android:textAppearance="@style/TextAppearance.PanzzPay.Label"
        android:textColor="@color/text_secondary" />

    <Spinner
        android:id="@+id/spinnerProvider"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_box"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_high" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/amount_label"
        android:textAppearance="@style/TextAppearance.PanzzPay.Label"
        android:textColor="@color/text_secondary" />

    <EditText
        android:id="@+id/etTestAmount"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_box"
        android:hint="@string/amount_hint"
        android:importantForAutofill="no"
        android:inputType="number"
        android:paddingHorizontal="14dp"
        android:text="@string/default_test_amount"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="14sp" />
</LinearLayout>
